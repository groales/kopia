# Plantilla de referencia para los valores usados en compose.yaml
# Este archivo NO se interpola automaticamente en el compose actual.

# Identidad del contenedor
HOSTNAME=Hostname
CONTAINER_NAME=Kopia

# Credenciales servidor Kopia (web/API)
USERNAME=User
SECRET_PASSWORD=CAMBIAR_POR_PASSWORD_SERVIDOR

# Password del repositorio (KOPIA_PASSWORD en environment)
SECRET=CAMBIAR_POR_PASSWORD_REPOSITORIO

# Rutas del host
KOPIA_DATA_DIR=/path/to/data/dir
KOPIA_REPOSITORY_DIR=/path/to/repository/dir
