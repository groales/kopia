# Zona horaria
TZ=Europe/Madrid

# Usuario para acceder a la UI/API de Kopia Server (tambien usado como USER del contenedor)
KOPIA_USER=admin
KOPIA_SERVER_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA

# Password del repositorio de backup
# Se expone como KOPIA_PASSWORD en el contenedor para desbloqueo automatico al arrancar
KOPIA_REPOSITORY_PASSWORD=CAMBIAR_POR_PASSWORD_REPOSITORIO

# Ruta EXTERNA al host donde se almacena el repositorio de backups
# DEBE estar en un disco/NAS diferente al host para tener valor como backup
# Ejemplos: /mnt/nas/kopia, /media/backup/kopia, /backup/kopia
KOPIA_REPOSITORY_PATH=/mnt/backup/kopia

# Ruta de los datos a respaldar (montada como solo lectura dentro del contenedor)
KOPIA_DATA_PATH=/ruta/a/los/datos
